{# Nunjucks macro for page header #}
{% macro page_header(title, meta) %}
<header class="wmc-page-header">
  <div class="wmc-page-header__inner">
    <h1 class="wmc-page-header__title">{{ title }}</h1>
    {% if meta %}
      <div class="wmc-page-header__meta">{{ meta }}</div>
    {% endif %}
  </div>
</header>
{% endmacro %}
