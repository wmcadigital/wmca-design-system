{# Nunjucks macro for share component #}
{% macro share(items) %}
<div class="wmc-share" role="group" aria-label="Share">
  {% for it in items %}
    <button class="wmc-share__item" type="button">
      <span class="wmc-share__icon" aria-hidden="true">{{ it.icon or '' }}</span>
      <span class="wmc-share__label">{{ it.label }}</span>
    </button>
  {% endfor %}
</div>
{% endmacro %}
