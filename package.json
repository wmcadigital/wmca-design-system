{
  "name": "ds-design-system",
  "version": "1.5.0",
  "description": "A library of typography, visual styles and user interface components which are documented for West Midlands Combined Authority.",
  "homepage": "https://designsystem.wmca.org.uk",
  "author": "WMCA",
  "main": "src/www/pages/index.njk",
  "files": [
    "build/*"
  ],
  "repository": "https://github.com/wmcadigital/wmca-design-system.git",
  "copyright": "WMCA",
  "sasslintConfig": ".sass-lint.yml",
  "browserslist": [
    "ie 11",
    "last 2 versions",
    "ie 8",
    "ie 9",
    "iOS 9"
  ],
  "buildDirs": {
    "local": {
      "baseUrl": "",
      "cdn": ""
    },
    "cloudcdn": {
      "baseUrl": "https://cloudcdn.wmca.org.uk/staging/ds/new/0/",
      "cdn": ""
    },
    "netlify": {
      "baseUrl": "/",
      "cdn": "https://wmcads.netlify.app"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  },
  "scripts": {
    "upgrade-packages": "ncu -u",
    "start": "gulp",
    "fresh": "npm install && gulp",
    "lint:all": "gulp lintAll",
    "lint:styles": "gulp lintStyles",
    "lint:templates": "gulp lintTemplates",
    "lint:scripts": "gulp lintScripts",
    "clean": "gulp clean",
    "build:all": "gulp buildAll",
    "build:styles": "gulp buildStyles",
    "build:templates": "gulp buildTemplates",
    "build:components": "gulp buildComponents",
    "build:scripts": "gulp buildScripts",
    "build:images": "gulp minImages",
    "build:sprites": "gulp buildSprites",
    "build:config": "gulp buildConfig",
    "build:netlify": "npm run build:all --build=netlify"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/standalone": "^7.26.2",
    "autoprefixer": "^10.4.20",
    "babel-eslint": "^10.1.0",
    "babel-loader": "^9.2.1",
    "browser-sync": "^3.0.3",
    "del": "^6.0.0",
    "dompurify": "^3.2.1",
    "eslint": "^6.0.0 || ^7.0.0 || >=8.0.0 || ^9.15.0",
    "eslint-config-airbnb-base": "^14.1.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-html": "^6.0.2",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-prettier": "^3.1.4",
    "glob": "^11.0.0",
    "gulp": "^4.0.2",
    "gulp-accessibility": "^3.1.1",
    "gulp-autoprefixer": "^7.0.1",
    "gulp-cached": "^1.1.1",
    "gulp-changed": "^4.0.3",
    "gulp-cheerio": "^1.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-cli": "^3.0.0",
    "gulp-concat": "^2.6.1",
    "gulp-data": "^1.3.1",
    "gulp-eslint": "^6.0.0",
    "gulp-flatten": "^0.4.0",
    "gulp-format-html": "^1.5.2",
    "gulp-htmlhint": "^4.0.2",
    "gulp-htmlmin": "^5.0.1",
    "gulp-imagemin": "^7.1.0",
    "gulp-json-format": "^2.0.0",
    "gulp-load-plugins": "^2.0.8",
    "gulp-merge-json": "^2.2.1",
    "gulp-nunjucks": "^6.0.0",
    "gulp-nunjucks-render": "^2.2.3",
    "gulp-plumber": "^1.2.1",
    "gulp-react-native-stylesheet-css": "^1.4.4",
    "gulp-remember": "^1.0.1",
    "gulp-rename": "^2.0.0",
    "gulp-replace": "^1.1.4",
    "gulp-sass": "^5.1.0",
    "gulp-sass-lint": "^1.4.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-svgmin": "^4.1.0",
    "gulp-svgstore": "^9.0.0",
    "gulp-terser": "^2.1.0",
    "gulp-uglify": "^3.0.2",
    "gulp-uglify-es": "^3.0.0",
    "marked": "^2.1.3",
    "npm-check-updates": "^17.1.11",
    "nunjucks": "^3.2.4",
    "nunjucks-markdown": "^2.0.1",
    "prettier": "^2.8.8",
    "sass": "^1.81.0",
    "webpack": "^5.96.1",
    "webpack-stream": "^7.0.0"
  },
  "dependencies": {
    "iframe-resizer": "^5.3.2",
    "path": "^0.12.7"
  }
}
