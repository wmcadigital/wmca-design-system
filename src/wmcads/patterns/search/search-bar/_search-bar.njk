{% macro wmcadsSearchbar(params) %}

{% set id = params.id if params.id else "searchBar" %}
{% set placeholder = params.placeholder if params.placeholder else "Search for news, campaigns, events…" %}
{% set label = params.label if params.label else "Search" %}

<form id="{{id}}_form">
    <label for="{{id}}_input" class="wmcads-search-bar__label visible-hidden">{{ label }}</label>
    <div class="wmcads-search-bar">
        <input id="{{id}}_input" aria-label="{{ label }}" type="text" class="wmcads-search-bar__input wmcads-fe-input" placeholder="{{placeholder}}">
        <button class="wmcads-search-bar__btn" type="submit">
            <svg><title>Search</title><use xlink:href="#wmcads-general-search" href="#wmcads-general-search"></use></svg>
        </button>
    </div>
</form>
{% endmacro %}
